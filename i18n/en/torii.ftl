request_tab_status_desc_103 = 103 Early Hints: preliminary headers were sent before the final response.
request_tab_status_desc_200 = 200 OK: the request completed successfully.
request_tab_status_desc_201 = 201 Created: a new resource was created successfully.
request_tab_status_desc_202 = 202 Accepted: the request was accepted for asynchronous processing.
request_tab_status_desc_203 = 203 Non-Authoritative Information: metadata may come from a transformed copy.
request_tab_status_desc_204 = 204 No Content: the request succeeded and returned no response body.
request_tab_status_desc_205 = 205 Reset Content: the client should reset the view that sent this request.
request_tab_status_desc_206 = 206 Partial Content: the response contains only part of the resource.
request_tab_status_desc_207 = 207 Multi-Status: the response includes multiple independent status values.
request_tab_status_desc_208 = 208 Already Reported: members already reported in a previous part of the response.
request_tab_status_desc_226 = 226 IM Used: the server fulfilled the request using instance-manipulations.
request_tab_status_desc_300 = 300 Multiple Choices: multiple representations are available for this resource.
request_tab_status_desc_301 = 301 Moved Permanently: the resource now has a permanent new URL.
request_tab_status_desc_302 = 302 Found: the resource is temporarily available at a different URL.
request_tab_status_desc_303 = 303 See Other: retrieve the resource using GET at another URL.
request_tab_status_desc_304 = 304 Not Modified: the cached representation is still valid.
request_tab_status_desc_305 = 305 Use Proxy: access requires a proxy (deprecated status).
request_tab_status_desc_306 = 306 (Unused): this status code is reserved and no longer used.
request_tab_status_desc_307 = 307 Temporary Redirect: repeat the same request at a temporary URL.
request_tab_status_desc_308 = 308 Permanent Redirect: repeat the same request at a permanent URL.
request_tab_status_desc_400 = 400 Bad Request: the server could not understand this request.
request_tab_status_desc_401 = 401 Unauthorized: authentication is required or failed.
request_tab_status_desc_402 = 402 Payment Required: reserved for future use.
