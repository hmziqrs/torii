request_tab_status_desc_405 = 405 Method Not Allowed: this HTTP method is not allowed for this resource.
request_tab_status_desc_406 = 406 Not Acceptable: no acceptable representation matched the request headers.
request_tab_status_desc_407 = 407 Proxy Authentication Required: authenticate with the proxy first.
request_tab_status_desc_408 = 408 Request Timeout: the server timed out waiting for this request.
request_tab_status_desc_409 = 409 Conflict: the request conflicts with current server state.
request_tab_status_desc_410 = 410 Gone: the resource is permanently unavailable.
request_tab_status_desc_411 = 411 Length Required: a Content-Length header is required.
request_tab_status_desc_412 = 412 Precondition Failed: request preconditions were not satisfied.
request_tab_status_desc_413 = 413 Payload Too Large: request body is larger than server limits.
request_tab_status_desc_414 = 414 URI Too Long: request target URI exceeds server limits.
request_tab_status_desc_415 = 415 Unsupported Media Type: request media type is not supported.
request_tab_status_desc_416 = 416 Range Not Satisfiable: requested range cannot be fulfilled.
request_tab_status_desc_417 = 417 Expectation Failed: Expect request-header requirements were not met.
request_tab_status_desc_418 = 418 I'm a teapot: the server refuses to brew coffee in a teapot.
request_tab_status_desc_421 = 421 Misdirected Request: request was sent to a server unable to respond.
request_tab_status_desc_422 = 422 Unprocessable Entity: syntax is valid but semantic validation failed.
request_tab_status_desc_423 = 423 Locked: the target resource is locked.
request_tab_status_desc_424 = 424 Failed Dependency: request failed because a previous action failed.
